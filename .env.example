# App
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Database (matches docker-compose.yml)
DATABASE_URL=postgresql://anime:anime@localhost:5432/anime_stream?schema=public

# Redis (matches docker-compose.yml)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT — generate strong secrets in real environments
JWT_ACCESS_SECRET=change-me-access
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_EXPIRES_IN=7d

# Jikan (MyAnimeList) — see spec 014
JIKAN_BASE_URL=https://api.jikan.moe/v4
JIKAN_CACHE_TTL=86400
JIKAN_MAX_RPS=3

# Video providers — see specs 004/005/006. Do NOT commit real keys.
DOODSTREAM_API_KEY=
DOODSTREAM_BASE_URL=https://doodapi.com/api

MIXDROP_API_KEY=
MIXDROP_EMAIL=
MIXDROP_BASE_URL=https://api.mixdrop.co/api

STREAMTAPE_LOGIN=
STREAMTAPE_API_KEY=
STREAMTAPE_BASE_URL=https://api.streamtape.com

# Stats sync cron (see spec 013)
SYNC_STATS_CRON=0 */6 * * *
</content>
